# Cloudflare Pages Redirects & Rewrites
# This allows dual hosting on both GitHub Pages and Cloudflare Pages
# without any code changes

# Rewrite /OP-CS_CONNECT/ paths to root (for cleaner URLs on Cloudflare)
/OP-CS_CONNECT/academics/*  /academics/:splat  200
/OP-CS_CONNECT/management/*  /management/:splat  200
/OP-CS_CONNECT/*  /:splat  200

# SPA fallback for client-side routing
/academics/*  /academics/index.html  200
/management/*  /management/index.html  200
/*  /index.html  200
